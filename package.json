{
  "name": "manganest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "node --test test/**/*.test.mjs",
    "lint": "eslint frontend/src frontend-admin/src shared",
    "format": "prettier --write frontend/src frontend-admin/src shared",
    "format:check": "prettier --check frontend/src frontend-admin/src shared",
    "typecheck": "npm run typecheck --prefix frontend && npm run typecheck --prefix frontend-admin",
    "build:reader": "npm run build --prefix frontend",
    "build:admin": "npm run build --prefix frontend-admin"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vue-tsc": "^3.3.4"
  }
}
